{
  "name": "@agent-desk/ui",
  "version": "1.6.0",
  "private": true,
  "description": "Renderer (vanilla JS + xterm.js + dockview-core) for agent-desk. Zero Electron deps; consumed by @agent-desk/desktop, @agent-desk/server, and @agent-desk/pwa.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@agent-desk/core": "*",
    "typescript": "^5.7.0"
  },
  "exports": {
    ".": "./src/web-entry.js",
    "./web": "./src/web-entry.js",
    "./web.html": "./src/web.html",
    "./renderer/*": "./src/renderer/*"
  },
  "files": [
    "src/**/*"
  ]
}
