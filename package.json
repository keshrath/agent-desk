{
  "name": "agent-desk",
  "version": "1.0.12",
  "description": "Unified control center for AI coding agents — terminals, dashboards, and orchestration in one app",
  "author": "Mathias Markl <mathias.markl@mukit.at>",
  "license": "MIT",
  "homepage": "https://github.com/keshrath/agent-desk",
  "repository": {
    "type": "git",
    "url": "https://github.com/keshrath/agent-desk.git"
  },
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/copy-vendor.js",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "watch": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,css,html}\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "npx playwright test",
    "package": "npm run build && electron-builder --config.npmRebuild=false",
    "package:win": "npm run build && electron-builder --win --config.npmRebuild=false",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "build": {
    "appId": "com.keshrath.agent-desk",
    "productName": "Agent Desk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "resources/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "keshrath",
      "repo": "agent-desk"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "agent-comm": "^1.2.10",
    "agent-discover": "^1.0.10",
    "agent-knowledge": "^1.3.10",
    "agent-tasks": "^1.9.8",
    "dockview-core": "^5.1.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2"
  }
}
